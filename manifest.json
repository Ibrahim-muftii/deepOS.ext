{
  "manifest_version": 3,
  "name": "DeepWork OS",
  "version": "1.0",
  "description": "Intervenes at distraction and enforces your declared work intent.",
  "permissions": [
    "storage",
    "webNavigation",
    "alarms",
    "tabs",
    "scripting",
    "idle"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["css/content.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["http://localhost:3000/*", "http://localhost:3001/*", "http://localhost:3002/*", "http://127.0.0.1:3000/*", "https://deepos.vercel.app/*"],
      "js": ["app-sync.js"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open DeepWork OS"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DeepWork OS"
  }
}
